-- =========================
-- DQL (QUERIES)
-- =========================

-- BASIC QUERIES
SELECT * FROM Member;

SELECT * FROM Member WHERE age > 21;

SELECT * FROM Member WHERE age > 20 AND gender = 'Male';

SELECT * FROM Member WHERE age BETWEEN 20 AND 23;

SELECT * FROM Member WHERE member_id IN (1,3,5);

SELECT * FROM Member WHERE name LIKE 'A%';

SELECT * FROM Member ORDER BY age DESC;

-- AGGREGATE FUNCTIONS
SELECT COUNT(*) AS total_members FROM Member;
SELECT AVG(age) AS average_age FROM Member;
SELECT MAX(age) AS max_age FROM Member;
SELECT MIN(age) AS min_age FROM Member;
SELECT SUM(price) AS total_price FROM Plan;

-- GROUP BY
SELECT gender, COUNT(*) AS total_members
FROM Member
GROUP BY gender;

-- HAVING
SELECT gender, COUNT(*) AS total_members
FROM Member
GROUP BY gender
HAVING COUNT(*) > 1;

-- INNER JOIN
SELECT m.name, p.plan_name
FROM Member m
INNER JOIN Membership ms ON m.member_id = ms.member_id
INNER JOIN Plan p ON ms.plan_id = p.plan_id;

-- LEFT JOIN
SELECT m.name, pay.amount
FROM Member m
LEFT JOIN Payment pay ON m.member_id = pay.member_id;

-- RIGHT JOIN
SELECT m.name, pay.amount
FROM Member m
RIGHT JOIN Payment pay ON m.member_id = pay.member_id;

-- SELF JOIN
SELECT A.name AS Member1, B.name AS Member2
FROM Member A
JOIN Member B
ON A.gender = B.gender AND A.member_id <> B.member_id;

-- SUBQUERIES
SELECT name
FROM Member
WHERE age = (SELECT MAX(age) FROM Member);

SELECT name
FROM Member
WHERE member_id IN (
    SELECT member_id FROM Payment WHERE amount > 2000
);

-- =========================
-- VIEW
-- =========================

CREATE VIEW Member_Plan_View AS
SELECT m.name, p.plan_name
FROM Member m
JOIN Membership ms ON m.member_id = ms.member_id
JOIN Plan p ON ms.plan_id = p.plan_id;

SELECT * FROM Member_Plan_View;

